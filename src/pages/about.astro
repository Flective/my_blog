---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="About this site and its author.">
  <div class="container">
    <div class="about-layout">
      <header class="page-header" style="padding-bottom: var(--space-xl);">
        <p class="page-header__eyebrow">About</p>
        <h1 class="page-header__title">Your Name Here</h1>
      </header>

      <div class="prose">
        <!-- ← Replace all of this with your actual bio -->
        <p>
          This is the about page. Write something true about yourself here.
          What do you actually do, think about, make? Why does this site exist?
        </p>

        <h2>What this site is</h2>
        <p>
          A place to finalize thoughts that would otherwise decay in chat history.
          Three buckets: short posts for quick ideas, essays for arguments that
          need room, and project pages for things being built.
        </p>

        <h2>Contact</h2>
        <p>
          Reach me at <a href="mailto:you@example.com">you@example.com</a>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
