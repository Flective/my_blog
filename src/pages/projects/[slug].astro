---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
}).format(project.data.date);

const statusLabel = { active: 'Active', completed: 'Completed', concept: 'Concept' };
---
<BaseLayout
  title={project.data.title}
  description={project.data.excerpt}
  ogType="article"
>
  <article class="container">
    <header class="page-header">
      <p class="page-header__eyebrow">Project</p>
      <h1 class="page-header__title">{project.data.title}</h1>
      <div class="page-header__meta">
        <time datetime={project.data.date.toISOString()}>{formattedDate}</time>
        {project.data.status && (
          <span class={`status status--${project.data.status}`}>
            {statusLabel[project.data.status]}
          </span>
        )}
        {project.data.tags && project.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <div class="ornament" style="margin-top: var(--space-2xl);">· · ·</div>
    <p style="text-align: center; margin-top: var(--space-lg);">
      <a href="/projects" style="font-size: 0.875rem; color: var(--text-muted); text-decoration: none;">
        ← Back to Projects
      </a>
    </p>
  </article>
</BaseLayout>
